# ─────────────────────────────────────────────────────────────────────────────
# waldocs / apps/web environment — TESTNET ONLY (hackathon)
#
# Copy this to apps/web/.env (NOT .env.local):
#   cp apps/web/.env.example apps/web/.env      # from repo root
#   cp .env.example .env                         # from inside apps/web
# Why .env (not .env.local): Next.js AND the Prisma CLI both read `.env` from
# this app dir; Prisma ignores `.env.local`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────────────────
# Matches docker-compose.yml (user/pass/db all "waldocs"). Used by Next.js +
# Prisma migrate/generate.
DATABASE_URL=postgresql://waldocs:waldocs@localhost:5432/waldocs

# ── Walrus Memory: relayer + testnet contract IDs ───────────────────────────
# Staging relayer = testnet. Do NOT point this at the mainnet relayer.
MEMWAL_SERVER_URL=https://relayer-staging.memory.walrus.xyz
# Testnet (staging) MemWal contract IDs — prefilled; leave as-is.
MEMWAL_PACKAGE_ID=0xcf6ad755a1cdff7217865c796778fabe5aa399cb0cf2eba986f4b582047229c6
MEMWAL_REGISTRY_ID=0xe80f2feec1c139616a86c9f71210152e2a7ca552b20841f2e192f99f75864437

# ── Walrus Memory: backend delegate credentials ─────────────────────────────
# Produced by the one-time bootstrap (pnpm seed:account). Leave blank until
# then, then paste the script's output here.
MEMWAL_PRIVATE_KEY=
MEMWAL_ACCOUNT_ID=

# ── LLM — structuring, merging, showcase, chat ─────────────────────────────
# Two providers, picked at runtime: if ANTHROPIC_API_KEY is set, Claude is used
# (and OpenRouter is ignored); otherwise it falls back to OpenRouter/Gemini.
#
# Option A — Claude (preferred when set). Anthropic API key (https://console.anthropic.com/).
# CLAUDE_MODEL is an Anthropic model id; defaults to claude-haiku-4-5-20251001.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
#
# Option B — OpenRouter/Gemini (fallback). API key from https://openrouter.ai/keys;
# GEMINI_MODEL is the OpenRouter model slug (a structured-output-capable model).
OPENROUTER_API_KEY=
GEMINI_MODEL=google/gemini-3.1-flash-lite

# ── App ─────────────────────────────────────────────────────────────────────
# Used to build absolute /protocol/<slug> and /app/<author>/<repo> URLs.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Manual import / publish-bypass (POST /api/import) ───────────────────────
# Shared bearer token to authorize DIRECT writes of protocol/app docs (no LLM
# merge). Leave UNSET to disable the endpoint entirely (returns 503). When set,
# callers must send `Authorization: Bearer <token>`.
WALDOCS_IMPORT_TOKEN=

# Demo mode: when "true", POST /api/publish does NO work (no LLM/Walrus/Postgres)
# and immediately returns a success-shaped response. For fast live demos only.
DUMMY_PUBLISH=

# ── Seed script ONLY (not used by the running app) ──────────────────────────
# Owner Sui wallet key (bech32 "suiprivkey1...") funded with TESTNET SUI.
# Signs the on-chain createAccount + addDelegateKey txs. Get testnet SUI at
# https://faucet.sui.io/ for this key's address. Safe to delete after seeding.
# Read by `pnpm seed:account` via --env-file=apps/web/.env.
OWNER_SUI_KEY=

# ── Claude Code skill ONLY (set in your shell, not the app) ─────────────────
# Where waldocs-publish POSTs. Defaults to http://localhost:3000 if unset.
# WALDOCS_API_URL=http://localhost:3000
